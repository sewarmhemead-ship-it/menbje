{
  "version": 2,
  "trailingSlash": false,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/dashboard/login.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/(favicon.ico|favicon.png|assets/.*)",
      "destination": "/dashboard/$1"
    },
    {
      "source": "/dashboard/login.html",
      "destination": "/dashboard/login.html"
    },
    {
      "source": "/dashboard/super-admin.html",
      "destination": "/dashboard/super-admin.html"
    },
    {
      "source": "/dashboard/index.html",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/dashboard/index.html"
    }
  ]
}
