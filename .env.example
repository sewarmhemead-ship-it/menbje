# Server
PORT=3000
BASE_URL=https://your-domain.com

# Super Admin (protected route /api/super-admin)
MASTER_KEY=vault-super-admin-key

# WhatsApp Business API (Meta Cloud API) — لوضع واتساب الحقيقي
# من Meta for Developers → تطبيقك → WhatsApp → API Setup
WHATSAPP_PHONE_ID=          # Phone number ID من لوحة WhatsApp
WHATSAPP_TOKEN=             # Access token (مؤقت أو دائم من System User)
WHATSAPP_VERIFY_TOKEN=     # كلمة تحقق تختارها أنت وتدخلها عند إعداد Webhook في Meta

# Optional: Twilio WhatsApp (alternative)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
